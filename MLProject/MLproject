name: Titanic_Workflow_CI_Ardian

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      data_dir: {type: string, default: "titanic_preprocessing"}
      n_estimators: {type: int, default: 100}
      max_depth: {type: int, default: 5}
    command: "python modelling.py --data_dir {data_dir} --n_estimators {n_estimators} --max_depth {max_depth}"
